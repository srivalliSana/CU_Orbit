<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orbit_background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/thread_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/orbit_surface"
        app:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_thread"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:title="Thread"
            app:titleTextColor="@color/orbit_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_thread"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/layout_thread_input_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/thread_app_bar" />

    <LinearLayout
        android:id="@+id/layout_thread_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/orbit_surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingBottom="12dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/orbit_border"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_thread_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_input"
            android:hint="Reply in thread..."
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:maxLines="5"
            android:minHeight="48dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:textSize="15sp"
            android:textColor="@color/orbit_text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/button_thread_send"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_send_button"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>