<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:background="?attr/selectableItemBackground">

    <!-- Header: Shown only for the first message in a group -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_message_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/image_profile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_person"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <TextView
            android:id="@+id/text_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/orbit_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/image_profile"
            app:layout_constraintTop_toTopOf="@id/image_profile"
            tools:text="Srivalli Sana" />

        <TextView
            android:id="@+id/text_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/orbit_text_secondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/text_user_name"
            app:layout_constraintStart_toEndOf="@id/text_user_name"
            app:layout_constraintTop_toTopOf="@id/text_user_name"
            tools:text="10:30 AM" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content: Aligned with the name, not the avatar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_message_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:autoLink="all"
            android:textColorLink="@color/orbit_primary"
            android:textColor="@color/orbit_text_primary"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"
            tools:text="Welcome to the CU Orbit space! This is where all university updates happen." />

        <!-- Media Views -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_message_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/orbit_border"
            app:strokeWidth="1dp">
            <ImageView
                android:id="@+id/image_message_content"
                android:layout_width="240dp"
                android:layout_height="180dp"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_voice_player"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/orbit_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <ImageView
                    android:id="@+id/button_play_voice"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/orbit_primary" />
                <SeekBar
                    android:id="@+id/voice_progress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingHorizontal="8dp" />
                <TextView
                    android:id="@+id/text_voice_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textSize="12sp"
                    android:textColor="@color/orbit_text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layout_file_attachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_message_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="@color/orbit_text_secondary" />
            <TextView
                android:id="@+id/text_file_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/orbit_text_primary"
                android:textSize="14sp"
                tools:text="Document.pdf" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_reactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:chipSpacingHorizontal="6dp"
            app:chipSpacingVertical="0dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Thread Indicator -->
        <LinearLayout
            android:id="@+id/layout_thread_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            tools:visibility="visible">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_person"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/orbit_border"
                app:strokeWidth="1dp" />

            <TextView
                android:id="@+id/text_thread_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/orbit_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="5 replies" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>