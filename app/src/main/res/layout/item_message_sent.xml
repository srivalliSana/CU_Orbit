<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:gravity="end">

    <TextView
        android:id="@+id/text_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:textColor="@color/orbit_text_secondary"
        android:textSize="11sp"
        tools:text="10:30 AM" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/orbit_blue_bg"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <TextView
                    android:id="@+id/text_message_body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/orbit_text_primary"
                    android:textSize="15sp"
                    android:autoLink="all"
                    android:textColorLink="@color/orbit_primary"
                    tools:text="Sent message content." />

                <!-- Media Views -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_message_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:id="@+id/image_message_content"
                        android:layout_width="200dp"
                        android:layout_height="150dp"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/card_voice_player"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <ImageView
                        android:id="@+id/button_play_voice"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/orbit_primary" />
                    <TextView
                        android:id="@+id/text_voice_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Voice Message"
                        android:textSize="12sp"
                        android:textColor="@color/orbit_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_file_attachment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_save"
                        app:tint="@color/orbit_text_secondary" />
                    <TextView
                        android:id="@+id/text_file_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/orbit_text_primary"
                        android:textSize="13sp"
                        tools:text="file.pdf" />
                </LinearLayout>

                <!-- Status icon (double check) -->
                <ImageView
                    android:id="@+id/image_message_status"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="2dp"
                    android:src="@android:drawable/checkbox_off_background"
                    android:visibility="gone"
                    app:tint="@color/orbit_primary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_reactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_thread_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            android:padding="2dp">
            <TextView
                android:id="@+id/text_thread_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/orbit_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="5 replies" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>