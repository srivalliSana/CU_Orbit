DB_NAME=cu_orbit
DB_USER=root
DB_PASS=change-me
DB_HOST=localhost
PORT=3000

# --- SSO ---
# Must be byte-identical to CampusOne's API_JWT_SECRET (which itself falls back
# to NEXTAUTH_SECRET there). Handoff tokens fail verification if these diverge.
CAMPUS_JWT_SECRET=

# Signs CU Orbit's own session tokens. Generate independently — never reuse
# CAMPUS_JWT_SECRET, or a leaked Orbit session becomes replayable at CampusOne.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORBIT_JWT_SECRET=

# Session lifetime (zeit/ms format).
ORBIT_SESSION_TTL=7d

# Passwordless phone login — returns a user for any phone number, with no
# credential of any kind. Leave unset. Enable only for local Android work until
# that client ships SSO, and never on an internet-facing deployment.
# ALLOW_LEGACY_AUTH=true

# --- Release publishing ---
# Machine credential for POST /api/system/register-release, called by the Gradle
# publish task. Must match RELEASE_TOKEN in the build environment. Without it
# the endpoint returns 503 and refuses to register anything.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
RELEASE_TOKEN=

# --- Schema management ---
#   safe  (default) create missing tables, never modify existing ones
#   alter           reconcile live tables with the models on every boot — dev only
#   off             touch nothing; schema comes solely from migrations/
# Column changes belong in migrations/, not in a boot-time ALTER.
DB_SYNC=safe
